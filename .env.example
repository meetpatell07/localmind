# ─── Neon Postgres ───────────────────────────
# Get from: neon.tech → Project → Connection Details
DATABASE_URL=postgresql://username:password@ep-xxxxx.aws.neon.tech/neondb?sslmode=require

# ─── Ollama (local) ─────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ─── Embedding ───────────────────────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text

# ─── Vault (local file storage) ─────────────
VAULT_PATH=./vault

# ─── Google OAuth (for Gmail + Calendar) ────
# 1. console.cloud.google.com → New project → Enable Gmail API + Calendar API
# 2. Create OAuth 2.0 credentials → Web Application
# 3. Add redirect URI: http://localhost:3000/api/connectors/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional — defaults to http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Telegram Bot ───────────────────────────
# 1. Message @BotFather on Telegram → /newbot → follow prompts
# 2. Copy the token here
TELEGRAM_BOT_TOKEN=
# 3. Set a random secret to verify webhook requests (any string, 1-256 chars)
TELEGRAM_WEBHOOK_SECRET=
